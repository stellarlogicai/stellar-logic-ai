# Helm AI Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Helm AI
APP_VERSION=1.0.0
APP_DESCRIPTION=AI-powered anti-cheat detection system
APP_URL=https://api.helm-ai.com
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# SERVER SETTINGS
# =============================================================================
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false
ACCESS_LOG=true

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
# PostgreSQL Database
DATABASE_URL=postgresql://helm_ai:your_password_here@localhost:5432/helm_ai
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=helm_ai
DATABASE_USER=helm_ai
DATABASE_PASSWORD=your_password_here
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# SQLite Database (for development)
SQLITE_DATABASE_URL=sqlite:///./helm_ai.db
SQLITE_DATABASE_PATH=./helm_ai.db

# =============================================================================
# REDIS SETTINGS
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password_here
REDIS_MAX_CONNECTIONS=20
REDIS_CONNECTION_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Settings
SECRET_KEY=your_super_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Settings
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# API Keys
API_KEY_HEADER=X-API-Key
API_KEY_PREFIX=Bearer
API_KEY_LENGTH=32

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_BURST=200

# =============================================================================
# BILLING & PAYMENTS
# =============================================================================
# Stripe Configuration
STRIPE_API_KEY=sk_live_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_SUCCESS_URL=https://helm-ai.com/billing/success
STRIPE_CANCEL_URL=https://helm-ai.com/billing/cancel

# Currency Settings
DEFAULT_CURRENCY=usd
SUPPORTED_CURRENCIES=usd,eur,gbp,cad,aud

# =============================================================================
# AI MODEL SETTINGS
# =============================================================================
# Model Paths
MODEL_PATH=./models
VISION_MODEL_PATH=./models/vision
AUDIO_MODEL_PATH=./models/audio
NETWORK_MODEL_PATH=./models/network
FUSION_MODEL_PATH=./models/fusion

# Model Configuration
MODEL_DEVICE=auto
MODEL_BATCH_SIZE=32
MODEL_MAX_WORKERS=4
MODEL_TIMEOUT=30
MODEL_CONFIDENCE_THRESHOLD=0.7
MODEL_RISK_THRESHOLD=0.8

# GPU Settings
CUDA_VISIBLE_DEVICES=0,1
GPU_MEMORY_FRACTION=0.8
ENABLE_MIXED_PRECISION=true

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5
LOG_ROTATION=daily

# Prometheus Metrics
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics
METRICS_ENABLED=true
METRICS_PATH=/metrics

# Health Checks
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# =============================================================================
# EMAIL SETTINGS
# =============================================================================
# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=noreply@helm-ai.com
EMAIL_FROM_NAME=Helm AI

# Email Templates
EMAIL_TEMPLATES_PATH=./templates/email
EMAIL_VERIFICATION_SUBJECT=Verify your Helm AI account
EMAIL_PASSWORD_RESET_SUBJECT=Reset your Helm AI password

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================
# CRM Integration
HUBSPOT_API_KEY=your_hubspot_api_key_here
SALESFORCE_API_KEY=your_salesforce_api_key_here
SALESFORCE_URL=https://yourinstance.salesforce.com

# Analytics
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID_HERE
MIXPANEL_TOKEN=your_mixpanel_token_here
SEGMENT_WRITE_KEY=your_segment_write_key_here

# Support
ZENDESK_API_KEY=your_zendesk_api_key_here
ZENDESK_SUBDOMAIN=helm-ai
INTERCOM_ACCESS_TOKEN=your_intercom_access_token_here

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# SSL/TLS
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem
SSL_CA_PATH=./ssl/ca.pem
SSL_VERIFY_CLIENT=false
SSL_CIPHERS=ECDHE-RSA-AES256-GCM-SHA384:ECDHE-RSA-AES128-GCM-SHA256
SSL_PROTOCOLS=TLSv1.2,TLSv1.3

# CORS
CORS_ORIGINS=https://helm-ai.com,https://app.helm-ai.com,https://admin.helm-ai.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Content Security Policy
CSP_ENABLED=true
CSP_SCRIPT_SRC=self 'unsafe-inline' https://js.stripe.com
CSP_STYLE_SRC=self 'unsafe-inline'
CSP_IMG_SRC=self data: https:
CSP_CONNECT_SRC=self https://api.stripe.com

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
# Caching
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
CACHE_KEY_PREFIX=helm_ai

# Connection Pooling
MAX_CONNECTIONS=100
MIN_CONNECTIONS=10
CONNECTION_TIMEOUT=30
IDLE_TIMEOUT=600

# Async Settings
ASYNC_POOL_SIZE=100
ASYNC_MAX_WORKERS=4
ASYNC_TIMEOUT=30

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Debug
DEBUG_SQL=false
DEBUG_REQUESTS=false
DEBUG_RESPONSES=false
PROFILING_ENABLED=false

# Testing
TEST_DATABASE_URL=sqlite:///./test.db
TEST_REDIS_URL=redis://localhost:6379/1
TEST_STRIPE_API_KEY=sk_test_your_test_key_here

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================
# Docker
DOCKER_REGISTRY=helm-ai
DOCKER_TAG=latest
DOCKER_PORT=8000
DOCKER_HOST=0.0.0.0

# Kubernetes
KUBERNETES_NAMESPACE=helm-ai
KUBERNETES_SERVICE_NAME=helm-ai-api
KUBERNETES_REPLICAS=3
KUBERNETES_CPU_LIMIT=1000m
KUBERNETES_MEMORY_LIMIT=2Gi

# =============================================================================
# BUSINESS SETTINGS
# =============================================================================
# Company
COMPANY_NAME=Helm AI
COMPANY_EMAIL=support@helm-ai.com
COMPANY_PHONE=+1-555-123-4567
COMPANY_ADDRESS=123 AI Security Lane, San Francisco, CA 94105

# Legal
PRIVACY_POLICY_URL=https://helm-ai.com/privacy
TERMS_OF_SERVICE_URL=https://helm-ai.com/terms
COOKIE_POLICY_URL=https://helm-ai.com/cookies

# Support
SUPPORT_EMAIL=support@helm-ai.com
SUPPORT_PHONE=+1-555-123-4567
SUPPORT_URL=https://helm-ai.com/support
DOCUMENTATION_URL=https://docs.helm-ai.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Features
ENABLE_BILLING=true
ENABLE_ANALYTICS=true
ENABLE_MONITORING=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_WEBHOOKS=true
ENABLE_API_DOCS=true
ENABLE_ADMIN_PANEL=true
ENABLE_CUSTOMER_PORTAL=true

# Beta Features
ENABLE_BETA_FEATURES=false
ENABLE_EXPERIMENTAL_MODELS=false
ENABLE_ADVANCED_ANALYTICS=false

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================
# Database Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=helm-ai-backups
BACKUP_S3_REGION=us-west-2

# File Backup
FILE_BACKUP_ENABLED=true
FILE_BACKUP_SCHEDULE=0 3 * * *
FILE_BACKUP_PATH=./backups
FILE_BACKUP_RETENTION_DAYS=7

# =============================================================================
# COMPLIANCE & AUDIT
# =============================================================================
# GDPR
GDPR_ENABLED=true
GDPR_DATA_RETENTION_DAYS=365
GDPR_ANONYMIZATION_ENABLED=true

# SOC 2
SOC2_ENABLED=true
SOC2_AUDIT_LOG_ENABLED=true
SOC2_ENCRYPTION_AT_REST=true
SOC2_ENCRYPTION_IN_TRANSIT=true

# HIPAA (if applicable)
HIPAA_ENABLED=false
HIPAA_ENCRYPTION_REQUIRED=false

# =============================================================================
# NOTIFICATIONS
# =============================================================================
# System Notifications
SYSTEM_NOTIFICATIONS_ENABLED=true
SYSTEM_NOTIFICATIONS_EMAIL=admin@helm-ai.com
SYSTEM_NOTIFICATIONS_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# User Notifications
USER_NOTIFICATIONS_ENABLED=true
USER_NOTIFICATIONS_EMAIL_ENABLED=true
USER_NOTIFICATIONS_SMS_ENABLED=false
USER_NOTIFICATIONS_PUSH_ENABLED=false

# =============================================================================
# API RATE LIMITING
# =============================================================================
# General API Rate Limiting
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=1000
API_RATE_LIMIT_WINDOW=3600
API_RATE_LIMIT_BURST=2000

# Per-User Rate Limiting
USER_RATE_LIMIT_ENABLED=true
USER_RATE_LIMIT_REQUESTS=100
USER_RATE_LIMIT_WINDOW=3600
USER_RATE_LIMIT_BURST=200

# Premium User Rate Limiting
PREMIUM_RATE_LIMIT_REQUESTS=1000
PREMIUM_RATE_LIMIT_WINDOW=3600
PREMIUM_RATE_LIMIT_BURST=2000

# =============================================================================
# WEBHOOK SETTINGS
# =============================================================================
# Webhook Configuration
WEBHOOK_ENABLED=true
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5

# Webhook Events
WEBHOOK_EVENTS_USER_CREATED=true
WEBHOOK_EVENTS_USER_UPDATED=true
WEBHOOK_EVENTS_SUBSCRIPTION_CREATED=true
WEBHOOK_EVENTS_SUBSCRIPTION_UPDATED=true
WEBHOOK_EVENTS_PAYMENT_SUCCEEDED=true
WEBHOOK_EVENTS_PAYMENT_FAILED=true
