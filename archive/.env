# Stellar Logic AI Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3001

# Security Configuration
JWT_SECRET=stellar-logic-ai-super-secret-jwt-key-change-in-production-2024
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database Configuration
DB_TYPE=sqlite
DB_PATH=./data/stellar-logic-ai.db

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/stellar-logic-ai.log

# External API Configuration (for fallback during development)
EXTERNAL_LLM_API_KEY=your-external-llm-api-key
EXTERNAL_LLM_BASE_URL=https://api.external-llm.com

# Poker Game Integration
POKER_GAME_URL=http://localhost:8080
POKER_GAME_API_KEY=stellar-poker-integration-key

# AI Model Configuration
MAX_TOKEN_LIMIT=100000
MODEL_TEMPERATURE=0.7
SAFETY_THRESHOLD=0.95

# Performance Configuration
REQUEST_TIMEOUT=30000
MAX_CONCURRENT_REQUESTS=100
CACHE_TTL=3600

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30000

# Development Configuration
ENABLE_CORS=true
ENABLE_DEBUG_LOGGING=true
ENABLE_HOT_RELOAD=true

