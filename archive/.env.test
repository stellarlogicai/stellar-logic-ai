# Test Environment Configuration
ENVIRONMENT=test
TESTING=true
LOG_LEVEL=DEBUG
SECRET_KEY=test-secret-key

# Database Configuration (SQLite for testing)
DB_TYPE=sqlite
DB_PATH=:memory:

# Redis Configuration (skip for testing)
REDIS_URL=

# AWS Configuration (mock for testing)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_S3_BUCKET=test-bucket
AWS_CLOUDWATCH_LOG_GROUP=test-log-group

# External Services (skip for testing)
GOOGLE_CLIENT_ID=test
GOOGLE_CLIENT_SECRET=test
MICROSOFT_CLIENT_ID=test
MICROSOFT_CLIENT_SECRET=test

# Email Services (skip for testing)
SENDGRID_API_KEY=test
MAILCHIMP_API_KEY=test

# Analytics (skip for testing)
GOOGLE_ANALYTICS_ID=test
MIXPANEL_TOKEN=test

# Support Services (skip for testing)
ZENDESK_SUBDOMAIN=test
ZENDESK_TOKEN=test
INTERCOM_TOKEN=test

# Performance Configuration
SLOW_QUERY_THRESHOLD=1.0
QUERY_CACHE_TTL=3600
MAX_CONCURRENT_ASYNC_OPS=10
ASYNC_OP_TIMEOUT=300
ASYNC_CLEANUP_INTERVAL=3600

# Cache Configuration
MEMORY_CACHE_SIZE=100
MEMORY_CACHE_MB=100

# Connection Pool Configuration
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=5
DB_CONNECTION_TIMEOUT=30
DB_IDLE_TIMEOUT=300
DB_MAX_LIFETIME=3600

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_INTERVAL=60
SYSTEM_STATS_INTERVAL=60

# Monitoring Configuration
METRICS_RETENTION_HOURS=24
LOG_BATCH_SIZE=100
LOG_FLUSH_INTERVAL=5
