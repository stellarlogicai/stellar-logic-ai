
# Stellar Logic AI Environment Variables

# Search API Keys (optional - can use free sources)
GOOGLE_SEARCH_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
BING_SEARCH_API_KEY=your_bing_api_key_here

# Vector Database (optional - uses local ChromaDB by default)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here

# Redis Cache (optional - uses local cache by default)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/stellar_logic_ai.log
